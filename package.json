{
  "name": "@andrelncampos/dscode",
  "version": "1.0.2",
  "description": "dscode CLI - AI coding assistant optimized for DeepSeek V4 in your terminal",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrelncampos/dscode.git"
  },
  "homepage": "https://github.com/andrelncampos/dscode",
  "bin": {
    "dscode": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/cli.js",
    "templates/tools/**",
    "templates/prompts/**",
    "templates/skills/**",
    "README.md",
    "LICENSE",
    "NOTICE",
    "docs/i18n/README.en.md",
    "docs/i18n/README.es.md",
    "docs/i18n/README.zh-Hans.md",
    "docs/i18n/README.hi.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/cli.tsx --bundle --platform=node --format=esm --target=node24 --outfile=dist/cli.js --banner:js=\"#!/usr/bin/env node\" --jsx=automatic --jsx-import-source=react --packages=external --log-override:empty-import-meta=silent",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "build": "npm run check && npm run bundle && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "test": "node src/tests/run-tests.mjs",
    "test:single": "node --import tsx --test",
    "debug:keys": "node scripts/debug-stdin.mjs",
    "debug:keys:extended": "node scripts/debug-stdin-extended.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "echo 'Run gitleaks locally: gitleaks detect --source . --verbose'",
    "security:all": "npm run security:audit",
    "prepack": "npm run build",
    "build:bundle": "node scripts/build-bundle.mjs",
    "build:sea": "node scripts/build-sea.mjs",
    "build:binary": "npm run build:bundle && npm run build:sea",
    "package:binary": "node scripts/package-binary.mjs",
    "validate:binary": "node scripts/validate-binary.mjs",
    "release:local": "npm run build && npm run build:binary && npm run package:binary && npm run validate:binary",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "ejs": "^5.0.2",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "ink": "^7.0.4",
    "ink-gradient": "^4.0.1",
    "minimatch": "^3.1.5",
    "openai": "^6.35.0",
    "react": "^19.2.5",
    "undici": "^7.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/ejs": "^3.1.5",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.8.3",
    "react-devtools-core": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
